# gitblend — Blender project .gitignore

# Working blend files (gitblend sidecar workflow)
# Only *.git.blend files are versioned — *.blend is Blender's live working copy.
*.blend
!*.git.blend
*.blend[0-9]
*.blend[0-9][0-9]

# gitblend safety backups
.gitblend-backups/

# Blender render output
# Uncomment if you do NOT want to commit renders:
# render/
# output/

# Python cache
__pycache__/
*.py[co]
*.pyo

# OS metadata
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# Editor temporaries
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-workspace

# Blender temp / crash files
/tmp/
